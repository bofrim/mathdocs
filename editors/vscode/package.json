{
  "name": "mathdocs-vscode",
  "displayName": "MathDocs",
  "description": "Preview Python MathDocs Markdown and LaTeX from static source metadata.",
  "version": "0.1.0",
  "publisher": "mathdocs",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://github.com/bofrim/mathdocs.git",
    "directory": "editors/vscode"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onCommand:mathdocs.previewDocument",
    "onCommand:mathdocs.previewCurrentFile",
    "onCommand:mathdocs.previewSelection",
    "onCommand:mathdocs.previewRange",
    "onCommand:mathdocs.toggleInlineRender",
    "onCommand:mathdocs.collapseMarkdownString",
    "onCommand:mathdocs.expandMarkdownString"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mathdocs.previewDocument",
        "title": "MathDocs: Preview File"
      },
      {
        "command": "mathdocs.previewCurrentFile",
        "title": "MathDocs: Preview Current File"
      },
      {
        "command": "mathdocs.previewSelection",
        "title": "MathDocs: Preview Selection"
      },
      {
        "command": "mathdocs.previewRange",
        "title": "MathDocs: Preview Range"
      },
      {
        "command": "mathdocs.toggleInlineRender",
        "title": "MathDocs: Toggle Inline Rendering"
      },
      {
        "command": "mathdocs.collapseMarkdownString",
        "title": "MathDocs: Collapse All Markdown Strings"
      },
      {
        "command": "mathdocs.expandMarkdownString",
        "title": "MathDocs: Expand All Markdown Strings"
      }
    ],
    "configuration": {
      "title": "MathDocs",
      "properties": {
        "mathdocs.serverPath": {
          "type": "string",
          "default": "",
          "description": "Path to the mathdocs-lsp binary. Empty uses PATH or the workspace target/debug binary."
        },
        "mathdocs.inlineRender.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Use a CodeLens spacer plus overlay to render MathDocs equations above code lines. This is experimental and may need per-theme tuning."
        }
      }
    }
  },
  "scripts": {
    "bundle": "esbuild src/extension.ts --bundle --platform=node --format=cjs --target=node20 --external:vscode --outfile=dist/extension.js && npm run copy:katex",
    "copy:katex": "node scripts/copy-katex-assets.js",
    "compile": "tsc -p ./ --noEmit && npm run bundle",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "dependencies": {
    "katex": "^0.16.22",
    "markdown-it": "^14.1.0",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "typescript": "^5.9.3"
  }
}
